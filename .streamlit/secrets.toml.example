# Copy to `.streamlit/secrets.toml` for local dev (gitignored):
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml

# --- Pinecone (required) ---
PINECONE_API_KEY = ""
PINECONE_INDEX_NAME = "memory-agent-domain"
PINECONE_MEMORY_INDEX_NAME = "memory-agent-memory"

# --- Google auth (pick ONE approach) ---

# OPTION A (recommended): Google AI Studio API key — no Vertex/OAuth required
GEMINI_API_KEY = ""

# OPTION B: service account for Vertex AI (only if your org allows JSON key download)
# [google_service_account]
# type = "service_account"
# project_id = "your-gcp-project-id"
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "your-sa@your-project.iam.gserviceaccount.com"
# client_id = "..."
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/..."

# OPTION C: OAuth client secret + token (paste from google_client_secret.json + google_token.json)
# [google_client_secret.web]
# client_id = "YOUR_CLIENT_ID.apps.googleusercontent.com"
# project_id = "your-gcp-project-id"
# client_secret = "GOCSPX-..."
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
#
# [google_token]
# token = "..."
# refresh_token = "..."
# token_uri = "https://oauth2.googleapis.com/token"
# client_id = "YOUR_CLIENT_ID.apps.googleusercontent.com"
# client_secret = "GOCSPX-..."
# scopes = ["https://www.googleapis.com/auth/cloud-platform"]

# --- Optional ---
# GOOGLE_VERTEX_LOCATION = "us-central1"
# GOOGLE_AUTH_MODE = "api_key"
# GEMINI_CHAT_MODEL = "gemini-2.5-flash"
# GEMINI_MULTIMODAL_MODEL = "gemini-2.5-flash"

# --- DeepSeek (disabled — uncomment when API key is available) ---
# DEEPSEEK_API_KEY = ""
