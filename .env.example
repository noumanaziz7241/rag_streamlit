# Pinecone (required)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=memory-agent-domain
PINECONE_MEMORY_INDEX_NAME=memory-agent-memory

# Google auth — pick ONE approach:
# Recommended: API key from Google AI Studio (works when org blocks SA keys / internal OAuth):
GEMINI_API_KEY=
# Optional Vertex AI (requires OAuth token or service account JSON key):
# Place google_client_secret.json in project root, or set:
# GOOGLE_CREDENTIALS_PATH=google_client_secret.json
# GOOGLE_VERTEX_LOCATION=us-central1
# Force API key even when google_client_secret.json exists:
# GOOGLE_AUTH_MODE=api_key

# Optional chat fallback when Google credentials are not configured
# DEEPSEEK_API_KEY=

# Optional model overrides
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_MULTIMODAL_MODEL=gemini-2.5-flash
